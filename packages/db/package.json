{
  "name": "@faralin/db",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "generate": "dotenv -e ../../.env -- prisma generate",
    "generate:ci": "prisma generate --schema prisma/schema.prisma",
    "migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "migrate:ci": "prisma migrate deploy --schema prisma/schema.prisma",
    "push": "dotenv -e ../../.env -- prisma db push",
    "push:ci": "prisma db push --schema prisma/schema.prisma",
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "seed:universities": "dotenv -e ../../.env -- tsx prisma/seed-universities.ts",
    "seed:universities:ci": "tsx prisma/seed-universities.ts",
    "studio": "dotenv -e ../../.env -- prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
